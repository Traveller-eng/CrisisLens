{
  "name": "crisislens",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "web",
    "functions"
  ],
  "scripts": {
    "dev": "npm run dev --workspace web",
    "build": "npm run build --workspace web",
    "functions:build": "npm run build --workspace functions",
    "seed:firestore": "node functions/scripts/seed-firestore.mjs",
    "extract-metric": "jest tests/metric-extraction.test.ts",
    "test": "jest --runInBand",
    "test:unit": "jest --runInBand --testPathPatterns unit",
    "test:integration": "jest --runInBand --testPathPatterns integration",
    "test:adversarial": "jest --runInBand --testPathPatterns adversarial --verbose",
    "test:coverage": "jest --runInBand --coverage"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9"
  },
  "dependencies": {
    "react-router-dom": "^7.14.2"
  }
}
